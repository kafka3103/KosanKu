{
  "expo": {
    "name": "KosanKu",
    "slug": "kosanku",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "bundleIdentifier": "com.kosanku.app",
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "KosanKu membutuhkan akses lokasi untuk mencari kosan terdekat.",
        "NSLocationAlwaysUsageDescription": "KosanKu membutuhkan akses lokasi untuk mencari kosan terdekat.",
        "NSCameraUsageDescription": "KosanKu membutuhkan akses kamera untuk foto profil, kamar, dan KTP.",
        "NSPhotoLibraryUsageDescription": "KosanKu membutuhkan akses galeri foto untuk upload foto."
      }
    },
    "android": {
      "package": "com.kosanku.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ],
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-location",
      "expo-image-picker",
      "expo-camera",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1A7F6E",
          "sounds": []
        }
      ],
      "@react-native-google-signin/google-signin",
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsImpl": "mapbox"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}