# ============================================================
# KosanKu — Environment Variables Template
# Salin file ini menjadi .env dan isi dengan nilai aktual
# ============================================================

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Maps (Android)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Payment Gateway (Midtrans Sandbox)
EXPO_PUBLIC_MIDTRANS_CLIENT_KEY=your-midtrans-client-key-sandbox
EXPO_PUBLIC_MIDTRANS_BASE_URL=https://api.sandbox.midtrans.com

# Firebase Cloud Messaging
EXPO_PUBLIC_FCM_SENDER_ID=your-firebase-sender-id
